APP_NAME=quant-trading
ENV=dev

EXCHANGE=binance
SYMBOL=ETHUSDT
TIMEFRAME=1m

PAPER_MODE=true
DRY_RUN=true

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/quant

FAST_MA=8
SLOW_MA=21
MIN_BARS=30

MAX_POSITION_USDT=1000
ORDER_USDT=100
COOLDOWN_SECONDS=30

REPLAY_ENABLED=false
REPLAY_LIMIT=500
REPLAY_SPEED_MS=50

DRIFT_THRESHOLD_BPS=20
DRIFT_CHECK_SECONDS=5

OPTIMIZE_ENABLED=false
OPTIMIZE_DAYS=365
OPTIMIZE_APPLY=true

API_HOST=0.0.0.0
API_PORT=8000
